---
layout: none
---
[
  {% assign all_posts = site.posts | concat: site.haiku | concat: site.lyrics | concat: site.xmas | concat: site.eulogies %}
  {% for post in all_posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%B %-d, %Y" | jsonify }},
    "category": {{ post.category | jsonify }},
    "content": {{ post.content | strip_html | strip_newlines | truncate: 1000 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
